# FinSight-AI Environment Configuration Example
# Copy this file to backend/.env and populate it with your local credentials.

# Google OAuth & Cloud Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_CLIENT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"

# Google Sheets Configuration
GOOGLE_SHEET_ID=your-google-sheet-id

# Security & Session Configuration
JWT_SECRET=your-jwt-secret-key

# AI Services
GEMINI_API_KEY=your-gemini-api-key
